{
  "version": 1,
  "purpose": "agent_created_tool_registry",
  "policy": {
    "default_directory": "Harness/scripts/tools",
    "safe_by_default": true,
    "prefer_read_only_default": true,
    "write_options_must_be_explicit": true,
    "project_specific_values_source": "Harness/config/project.json"
  },
  "tools": [
    {
      "name": "harness_docs_check",
      "path": "Harness/scripts/tools/harness_docs_check.py",
      "purpose": "Harness/docs와 Harness/config/docs.json의 문서 발견 경로, on-demand 읽기 정책, 요청별 문서 참고 여부를 점검한다.",
      "inputs": [
        "Harness/config/docs.json",
        "Harness/docs/README.md",
        "--request"
      ],
      "outputs": [
        "docs_policy_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_docs_check.py --json"
    },
    {
      "name": "harness_context",
      "path": "Harness/scripts/tools/harness_context.py",
      "purpose": "작업 시작 시 Harness 상태, 다음 작업, 오늘 사이클, 도구 정보를 짧게 요약해 에이전트의 초기 읽기 비용을 줄인다.",
      "inputs": [
        "HARNESS.md",
        "Harness/state.md",
        "Harness/next.md",
        "Harness/config/project.json",
        "Harness/config/docs.json",
        "Harness/config/cycle_policy.json",
        "Harness/scripts/tools/tool_manifest.json",
        "--request"
      ],
      "outputs": [
        "short_text",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_context.py --json"
    },
    {
      "name": "harness_doctor",
      "path": "Harness/scripts/tools/harness_doctor.py",
      "purpose": "Harness 문서, 설정, 도구 manifest가 서로 맞는지 빠르게 점검한다.",
      "inputs": [
        "HARNESS.md",
        "AGENTS.md",
        "CLAUDE.md",
        "Harness/config/*.json",
        "Harness/scripts/tools/tool_manifest.json"
      ],
      "outputs": [
        "check_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_doctor.py --json"
    },
    {
      "name": "harness_scan",
      "path": "Harness/scripts/tools/harness_scan.py",
      "purpose": "Unreal 프로젝트 구조를 훑어 project.json 후보와 주요 Source/Config/Plugin 정보를 요약한다.",
      "inputs": [
        "*.uproject",
        "Source/**/*.Build.cs",
        "Source/**/*Target.cs",
        "Config/*.ini",
        "Plugins/**/*.uplugin",
        "Content/**/*.umap with --include-assets"
      ],
      "outputs": [
        "scan_summary",
        "project_json_candidate",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_scan.py --json"
    },
    {
      "name": "harness_cycle",
      "path": "Harness/scripts/tools/harness_cycle.py",
      "purpose": "짧은 사이클 로그 항목을 dry run으로 만들고, 명시적 --write가 있을 때만 오늘 cycles 파일에 추가한다. changed, verified, remaining 항목은 반복 입력할 수 있다.",
      "inputs": [
        "title",
        "--changed",
        "--verified",
        "--remaining",
        "--date"
      ],
      "outputs": [
        "cycle_log_entry"
      ],
      "writes_files": "only_with_--write",
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_cycle.py tool_check --changed dry_run --changed multiple_entries --verified json --json"
    },
    {
      "name": "harness_diff_guard",
      "path": "Harness/scripts/tools/harness_diff_guard.py",
      "purpose": "git status 또는 생성물 디렉터리 감지를 통해 Unreal 작업에서 위험한 변경 범위를 빠르게 요약한다.",
      "inputs": [
        "git status --short when available",
        "Binaries/",
        "Intermediate/",
        "Saved/",
        "DerivedDataCache/",
        "changed Source headers and Build.cs files"
      ],
      "outputs": [
        "risk_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_diff_guard.py --json"
    },
    {
      "name": "harness_handoff",
      "path": "Harness/scripts/tools/harness_handoff.py",
      "purpose": "다른 에이전트나 새 세션으로 넘길 최소 컨텍스트를 dry run으로 생성하고, 명시적 --write가 있을 때만 handoff 문서를 쓴다.",
      "inputs": [
        "harness_context",
        "harness_diff_guard",
        "Harness/next.md",
        "Harness/cycles/YYYY-MM-DD.md",
        "--request"
      ],
      "outputs": [
        "handoff_markdown"
      ],
      "writes_files": "only_with_--write",
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_handoff.py --request \"검증\""
    },
    {
      "name": "harness_verify_all",
      "path": "Harness/scripts/tools/harness_verify_all.py",
      "purpose": "작업 종료 전 에이전트가 doctor, JSON 파싱, Python 컴파일, scan, diff guard, build readiness를 한 번에 확인한다.",
      "inputs": [
        "harness_doctor",
        "harness_context",
        "harness_scan",
        "harness_diff_guard",
        "Harness/config/*.json",
        "Harness/scripts/**/*.py"
      ],
      "outputs": [
        "verification_bundle_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_verify_all.py --json"
    },
    {
      "name": "harness_migration_audit",
      "path": "Harness/scripts/tools/harness_migration_audit.py",
      "purpose": "구버전 Harness가 들어간 대상 프로젝트를 이식하기 전에 보존, 갱신, 정리 항목을 읽기 전용으로 점검한다.",
      "inputs": [
        "--target",
        "target/Harness/state.md",
        "target/Harness/next.md",
        "target/Harness/cycles/",
        "target/Harness/config/project.json",
        "target/Harness/config/docs.json",
        "target/Harness/docs/",
        "target/ProjectDocs/ optional external documents",
        "target/Harness/doc/ legacy project documents",
        "target active docs"
      ],
      "outputs": [
        "migration_audit_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_migration_audit.py --target . --json"
    },
    {
      "name": "harness_state_check",
      "path": "Harness/scripts/tools/harness_state_check.py",
      "purpose": "state.md/next.md/cycles/ 문서가 비대해지거나 작업 이력이 섞이는지, 구버전 스크립트 경로가 남았는지 점검한다.",
      "inputs": [
        "--target",
        "Harness/state.md",
        "Harness/next.md",
        "Harness/README.md",
        "Harness/cycles/"
      ],
      "outputs": [
        "doc_health_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_state_check.py --target . --json"
    },
    {
      "name": "harness_python_check",
      "path": "Harness/scripts/tools/harness_python_check.py",
      "purpose": "Python 3 실행 가능 여부와 Unreal Python 후보를 짧게 점검하고, 없을 경우 수동 설치 안내만 제공한다.",
      "inputs": [
        "python --version",
        "py -3 --version",
        "python3 --version",
        "Harness/config/project.json"
      ],
      "outputs": [
        "python_runtime_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_python_check.py --json"
    },
    {
      "name": "harness_init_plan",
      "path": "Harness/scripts/tools/harness_init_plan.py",
      "purpose": "새 프로젝트 초기화나 템플릿 이식 시 보존, 채울 값, 검증 명령을 짧은 계획으로 요약한다.",
      "inputs": [
        "HARNESS.md",
        "Harness/",
        "*.uproject",
        "Harness/config/project.json",
        "Harness/config/docs.json"
      ],
      "outputs": [
        "init_or_migration_plan",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_init_plan.py --json"
    },
    {
      "name": "harness_docs_index",
      "path": "Harness/scripts/tools/harness_docs_index.py",
      "purpose": "Harness/docs 문서를 전체로 읽기 전에 파일별 제목과 heading만 인덱싱해 읽을 범위를 줄인다.",
      "inputs": [
        "Harness/config/docs.json",
        "Harness/docs/**/*.md",
        "--max-files",
        "--max-headings"
      ],
      "outputs": [
        "docs_heading_index",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_docs_index.py --json"
    },
    {
      "name": "harness_project_fill",
      "path": "Harness/scripts/tools/harness_project_fill.py",
      "purpose": "Unreal 프로젝트 구조를 스캔해 Harness/config/project.json의 빈 필드 후보를 만들고, --write가 있을 때만 채운다.",
      "inputs": [
        "*.uproject",
        "Source/**/*.Build.cs",
        "Source/**/*Target.cs",
        "Harness/config/project.json",
        "--write",
        "--overwrite"
      ],
      "outputs": [
        "project_json_candidate",
        "merged_project_json",
        "json"
      ],
      "writes_files": "only_with_--write",
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_project_fill.py --json"
    },
    {
      "name": "harness_cycle_summary",
      "path": "Harness/scripts/tools/harness_cycle_summary.py",
      "purpose": "최근 cycles 로그에서 변경, 검증, 남은 일을 짧게 요약해 누적 기록을 매번 길게 읽지 않게 한다.",
      "inputs": [
        "Harness/cycles/*.md",
        "--limit"
      ],
      "outputs": [
        "cycle_summary",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "verify": "python Harness/scripts/tools/harness_cycle_summary.py --json"
    },
    {
      "name": "harness_unreal_risk",
      "path": "Harness/scripts/tools/harness_unreal_risk.py",
      "purpose": "변경 파일 목록에서 Build.cs, Public 헤더, UPROPERTY/UFUNCTION, Config, 에셋 변경 같은 Unreal 위험 신호만 추린다.",
      "inputs": [
        "git status --short",
        "changed Source/ files",
        "changed Config/ files",
        "changed Content/ assets"
      ],
      "outputs": [
        "unreal_risk_report",
        "json"
      ],
      "writes_files": false,
      "safe_by_default": true,
      "context_check": true,
      "verify": "python Harness/scripts/tools/harness_unreal_risk.py --json"
    }
  ]
}
