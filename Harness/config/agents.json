{
  "version": 1,
  "purpose": "worker_instruction_map",
  "default_worker": "current_app",
  "shared_rules": "HARNESS.md",
  "supported_workers": {
    "codex": {
      "display_name": "Codex",
      "instruction_file": "AGENTS.md",
      "can_be_primary_worker": true,
      "notes": "When working in the Codex app or CLI, AGENTS.md routes the worker to HARNESS.md."
    },
    "claude_code": {
      "display_name": "Claude Code",
      "instruction_file": "CLAUDE.md",
      "can_be_primary_worker": true,
      "notes": "When working in Claude Code, CLAUDE.md routes the worker to HARNESS.md."
    }
  },
  "handoff": {
    "automatic_switching": false,
    "requires_human_assignment": true,
    "record_in_cycle_log": true,
    "new_worker_reads_first": [
      "HARNESS.md",
      "Harness/state.md",
      "Harness/next.md",
      "Harness/cycles/YYYY-MM-DD.md",
      "git status --short",
      "git diff"
    ]
  },
  "credentials": {
    "managed_by_each_app": true,
    "never_store_in_harness": true
  },
  "record_paths": {
    "state": "Harness/state.md",
    "next": "Harness/next.md",
    "cycle_log": "Harness/cycles/YYYY-MM-DD.md"
  }
}
