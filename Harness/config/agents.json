{
  "version": 1,
  "defaults": {
    "worker": "codex",
    "reviewer": "gemini_cli",
    "log_organizer": "goose_ollama"
  },
  "fallback_order": {
    "worker": ["codex"],
    "reviewer": ["gemini_cli", "codex"],
    "log_organizer": ["goose_ollama", "codex"]
  },
  "agents": {
    "codex": {
      "display_name": "Codex",
      "provider": "openai",
      "type": "current_session",
      "roles": ["worker", "reviewer"],
      "can_edit": true,
      "can_run_commands": true,
      "command": null,
      "health_check": null,
      "notes": "현재 Codex 세션의 기본 작업자."
    },
    "gemini_cli": {
      "display_name": "Gemini CLI",
      "provider": "google",
      "type": "external_cli",
      "roles": ["reviewer"],
      "can_edit": false,
      "can_run_commands": false,
      "command": ["gemini", "--skip-trust", "-p"],
      "health_check": ["gemini", "--version"],
      "auth_check": {
        "command": ["gemini", "--skip-trust", "-p", "OK만 출력해."],
        "expected_contains": "OK",
        "on_failure": "mark_unavailable_and_use_fallback"
      },
      "auth_setup_hint": "`gemini`를 대화형으로 한 번 실행하고 브라우저에서 로그인을 완료한다. 인증 정보는 Harness/config에 저장하지 않는다.",
      "notes": "기본 외부 리뷰어. 작업자로 쓰려면 사람이 별도 사이클에서 권한과 책임 범위를 명시해야 한다."
    },
    "goose_ollama": {
      "display_name": "Goose + Ollama",
      "provider": "local_ollama",
      "type": "external_cli",
      "roles": ["log_organizer", "review_summarizer", "context_compactor"],
      "can_edit": false,
      "can_write_files": false,
      "can_run_commands": false,
      "output_mode": "stdout_only",
      "command": ["goose", "run", "--no-session", "--quiet", "--provider", "ollama"],
      "health_check": ["goose", "--version"],
      "auth_check": null,
      "install_hint": "Goose CLI와 Ollama가 설치되어 있어야 한다. 설치되지 않았거나 PATH에 없으면 Codex가 요약을 대신한다.",
      "notes": "로그, diff, 외부 리뷰, 사이클 기록을 한국어로 정리하는 선택 보조자. 파일 수정과 커밋은 금지한다."
    }
  },
  "failure_policy": {
    "if_worker_unavailable": "stop_or_wait_for_human_worker_assignment",
    "if_reviewer_unavailable": "try_next_reviewer_or_self_review_with_note",
    "if_log_organizer_unavailable": "fallback_to_codex_summary_with_note",
    "record_unavailable_agent": true,
    "never_store_credentials": true,
    "unavailable_signals": [
      "quota_exceeded",
      "rate_limited",
      "authentication_required",
      "command_not_found",
      "trusted_workspace_required",
      "network_error"
    ]
  },
  "record_paths": {
    "state": "Harness/state.md",
    "next": "Harness/next.md",
    "cycle_log": "Harness/cycles/YYYY-MM-DD.md",
    "reviews": "Harness/reviews"
  }
}
