{
  "version": 1,
  "defaults": {
    "worker": "codex",
    "reviewer": "gemini_cli"
  },
  "fallback_order": {
    "worker": ["codex"],
    "reviewer": ["gemini_cli", "codex"]
  },
  "agents": {
    "codex": {
      "display_name": "Codex",
      "provider": "openai",
      "type": "current_session",
      "roles": ["worker", "reviewer"],
      "can_edit": true,
      "can_run_commands": true,
      "command": null,
      "health_check": null,
      "notes": "현재 Codex 세션의 기본 작업자."
    },
    "gemini_cli": {
      "display_name": "Gemini CLI",
      "provider": "google",
      "type": "external_cli",
      "roles": ["reviewer"],
      "can_edit": false,
      "can_run_commands": false,
      "command": ["gemini", "--skip-trust", "-p"],
      "health_check": ["gemini", "--version"],
      "auth_check": {
        "command": ["gemini", "--skip-trust", "-p", "OK만 출력해."],
        "expected_contains": "OK",
        "on_failure": "mark_unavailable_and_use_fallback"
      },
      "auth_setup_hint": "`gemini`를 대화형으로 한 번 실행하고 브라우저에서 로그인을 완료한다. 인증 정보는 Harness/config에 저장하지 않는다.",
      "notes": "기본 외부 리뷰어. 작업자로 쓰려면 사람이 별도 사이클에서 권한과 책임 범위를 명시해야 한다."
    }
  },
  "failure_policy": {
    "if_worker_unavailable": "stop_or_wait_for_human_worker_assignment",
    "if_reviewer_unavailable": "try_next_reviewer_or_self_review_with_note",
    "record_unavailable_agent": true,
    "never_store_credentials": true,
    "unavailable_signals": [
      "quota_exceeded",
      "rate_limited",
      "authentication_required",
      "command_not_found",
      "trusted_workspace_required",
      "network_error"
    ]
  },
  "record_paths": {
    "state": "Harness/state.md",
    "next": "Harness/next.md",
    "cycle_log": "Harness/cycles/YYYY-MM-DD.md",
    "reviews": "Harness/reviews"
  }
}
