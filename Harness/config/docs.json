{
  "version": 1,
  "doc_roots": [
    "ProjectDocs"
  ],
  "entry_points": [
    "ProjectDocs/README.md"
  ],
  "read_policy": {
    "default": "on_demand",
    "read_when": [
      "사용자가 기획서, GDD, 명세, 구현기준서, 체크리스트, 시나리오, 검증 기준 참고를 요청할 때",
      "작업이 게임 규칙, 시뮬레이션 요구사항, 입력, UX 흐름, 레벨 의도, 캐릭터/시스템 설계와 관련될 때",
      "Source, Config, 에셋만으로 구현 의도나 성공 기준을 판단하기 어려울 때",
      "기존 구현과 프로젝트 문서가 충돌할 가능성이 있을 때"
    ],
    "do_not_read_when": [
      "단순 컴파일 오류 수정",
      "명확한 빌드 설정 오류 수정",
      "포맷, 작은 리네임, 파일 이동",
      "사용자가 이미 구체적인 구현 기준을 준 경우"
    ]
  },
  "request_hints": {
    "read": [
      "기획",
      "GDD",
      "명세",
      "구현기준",
      "체크리스트",
      "시나리오",
      "검증 기준",
      "요구사항",
      "규칙",
      "밸런스",
      "UX",
      "UI",
      "레벨",
      "캐릭터",
      "시뮬레이션",
      "설계"
    ],
    "skip": [
      "컴파일 오류",
      "빌드 오류",
      "포맷",
      "리네임",
      "파일 이동"
    ]
  }
}
