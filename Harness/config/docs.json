  "entry_points": [
    "Harness/docs/README.md"
  ],
  "optional_external_roots": [
    "ProjectDocs",
    "Docs",
    "DesignDocs"
  ],
  "read_policy": {
    "default": "on_demand",
    "read_when": [
      "the user asks to reference design docs, GDD, specs, implementation standards, checklists, scenarios, or validation criteria",
      "the task involves game rules, simulation requirements, input, UX flow, level intent, character design, or system design",
      "Source, Config, and assets are not enough to infer implementation intent or success criteria",
      "existing implementation may conflict with project docs"
    ],
    "do_not_read_when": [
      "simple compile error fix",
      "clear build configuration fix",
      "formatting, small rename, or file move",
      "the user already gave concrete implementation criteria"
    ]
  },
