{
  "version": 1,
  "mode": "primary_single_worker",
  "default_max_cycles": 1,
  "cycle_flow": [
    "worker_reads_state_next_and_cycle_log",
    "worker_implements_or_improves",
    "worker_runs_smallest_reasonable_verification",
    "worker_checks_unreal_risks",
    "worker_records_short_cycle_result",
    "worker_updates_state_snapshot_if_confirmed",
    "worker_updates_next_items_if_unresolved"
  ],
  "worker_switching": {
    "allowed": true,
    "requires_human_assignment": true,
    "record_in_cycle_log": true,
    "recommended_when": [
      "model_quota_exhausted",
      "context_too_large",
      "human_requested_switch"
    ],
    "new_worker_reads_first": [
      "Harness/state.md",
      "Harness/next.md",
      "Harness/cycles/YYYY-MM-DD.md",
      "git_status_and_diff"
    ],
    "avoid_when": [
      "public_api_change",
      "blueprint_exposed_name_change",
      "build_cs_change",
      "save_data_change",
      "binary_asset_change",
      "multi_module_refactor"
    ]
  },
  "recording_rules": {
    "cycle_log_is_short": true,
    "cycle_log_contains": [
      "changed",
      "verified",
      "remaining"
    ],
    "state_is_not_a_work_log": true,
    "state_keeps_only_latest_confirmed_facts": true,
    "next_keeps_only_unresolved_work": true,
    "avoid_duplicate_state_next_cycles": true
  },
  "language_policy": {
    "default_human_language": "ko",
    "state_language": "ko",
    "cycle_log_language": "ko",
    "next_language": "ko",
    "preserve_original_for": [
      "code",
      "identifiers",
      "file_paths",
      "commands",
      "error_messages",
      "logs",
      "quoted_output"
    ]
  },
  "stop_conditions": [
    "same_issue_repeated_twice",
    "build_failed_twice",
    "unexpected_large_diff",
    "unsafe_public_api_or_blueprint_change",
    "human_stop_requested"
  ]
}
